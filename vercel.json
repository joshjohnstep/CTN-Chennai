{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/api/newsletter/subscribe", "destination": "/api/newsletter/subscribe" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
